    "dotenv": "17.4.2",
    "nitro": "3.0.260522-beta",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "prisma": "7.8.0",
