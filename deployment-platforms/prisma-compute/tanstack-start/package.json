    "compute:deploy": "npx @prisma/cli@latest app deploy --env .env",
    "compute:open": "npx @prisma/cli@latest app open",
    "compute:logs": "npx @prisma/cli@latest app logs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
