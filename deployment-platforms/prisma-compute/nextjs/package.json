{
  "name": "prisma-compute-nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "compute:login": "npx @prisma/cli@latest auth login",
    "compute:database:create": "npx @prisma/cli@latest database create prisma-compute-nextjs --branch main",
    "compute:deploy": "npx @prisma/cli@latest app deploy --env .env",
    "compute:open": "npx @prisma/cli@latest app open",
    "compute:logs": "npx @prisma/cli@latest app logs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.4.2",
    "next": "16.2.7",
    "pg": "8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
