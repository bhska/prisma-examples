generator client {
  provider   = "prisma-client"
  output     = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
