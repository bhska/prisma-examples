{
  "name": "typescript-graphql",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/src/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc && npm run build:schema",
    "build:schema": "tsx src/schema/index.ts",
    "generate": "npm -s run generate:prisma",
    "generate:prisma": "prisma generate"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@pothos/core": "4.12.0",
    "@pothos/plugin-prisma": "4.14.2",
    "@prisma/client": "7.5.0",
    "@prisma/adapter-pg": "7.5.0",
    "dotenv": "17.3.1",
    "graphql": "16.13.1",
    "graphql-scalars": "1.25.0",
    "graphql-yoga": "5.18.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "@types/pg": "^8.18.0"
  }
}
