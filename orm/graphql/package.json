{
  "name": "typescript-graphql",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc && npm run build:schema",
    "build:schema": "tsx src/schema/index.ts",
    "generate": "npm -s run generate:prisma",
    "generate:prisma": "prisma generate"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@pothos/core": "4.7.0",
    "@pothos/plugin-prisma": "4.9.1",
    "@prisma/client": "6.18.0",
    "@prisma/extension-accelerate": "2.0.2",
    "dotenv": "16.6.1",
    "graphql": "16.11.0",
    "graphql-scalars": "1.24.2",
    "graphql-yoga": "5.14.0"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "prisma": "6.18.0",
    "tsx": "4.20.6",
    "typescript": "5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
