{
  "name": "graphql-hapi",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc",
    "generate": "npm -s run generate:prisma && npm -s run generate:nexus",
    "generate:prisma": "prisma generate",
    "generate:nexus": "tsx src/schema"
  },
  "dependencies": {
    "@apollo/server": "4.13.0",
    "@as-integrations/hapi": "2.0.2",
    "@hapi/hapi": "21.4.7",
    "@prisma/client": "7.0.0",
    "@prisma/adapter-pg": "7.0.0",
    "@types/node": "22.18.12",
    "dotenv": "16.6.1",
    "graphql": "16.11.0",
    "graphql-scalars": "1.24.2",
    "nexus": "1.3.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/hapi__hapi": "21.0.0",
    "@types/node": "22.18.12",
    "dotenv": "^17.2.1",
    "prisma": "7.0.0",
    "tsx": "4.20.6",
    "typescript": "5.8.2",
    "@types/pg": "^8.15.6"
  }
}