{
  "name": "subscriptions-pubsub",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc",
    "generate": "npm -s run generate:prisma && npm -s run generate:nexus",
    "generate:prisma": "prisma generate",
    "generate:nexus": "tsx src/schema"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@apollo/server": "4.12.2",
    "@as-integrations/express5": "1.1.2",
    "@prisma/client": "6.18.0",
    "@prisma/extension-accelerate": "2.0.2",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "graphql": "16.11.0",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "5.16.2",
    "nexus": "1.3.0",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/node": "22.15.32",
    "@types/ws": "8.18.1",
    "prisma": "6.18.0",
    "tsx": "4.20.6",
    "typescript": "5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
