{
  "name": "subscriptions-pubsub",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/src/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc",
    "generate": "npm -s run generate:prisma && npm -s run generate:nexus",
    "generate:prisma": "prisma generate",
    "generate:nexus": "tsx src/schema"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@as-integrations/express5": "1.1.2",
    "@prisma/client": "7.5.0",
    "@prisma/adapter-pg": "7.5.0",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "graphql": "16.13.1",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "6.0.7",
    "nexus": "1.3.0",
    "ws": "8.19.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "@types/pg": "^8.18.0"
  }
}
