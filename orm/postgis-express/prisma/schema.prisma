generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id       Int                                  @id @default(autoincrement())
  name     String
  location Unsupported("\"public\".geography")?
}

model User {
  id       Int                                  @id @default(autoincrement())
  name     String
  location Unsupported("\"public\".geography")?
}
