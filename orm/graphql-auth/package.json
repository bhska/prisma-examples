{
  "name": "graphql-auth",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/src/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc",
    "generate": "npm -s run generate:prisma && npm -s run generate:nexus",
    "generate:prisma": "prisma generate",
    "generate:nexus": "tsx src/schema"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@prisma/client": "7.5.0",
    "@prisma/adapter-pg": "7.5.0",
    "bcryptjs": "3.0.3",
    "dotenv": "^17.3.1",
    "graphql": "16.13.1",
    "graphql-middleware": "6.1.35",
    "graphql-scalars": "1.25.0",
    "graphql-shield": "7.6.5",
    "jsonwebtoken": "9.0.3",
    "nexus": "1.3.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "3.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.0",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "@types/pg": "^8.18.0"
  }
}
