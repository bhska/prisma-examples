generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                       Int     @id @default(autoincrement())
  email                    String  @unique
  name                     String?
  posts                    Post[]
  acceptTermsAndConditions Boolean
}

model Post {
  id       Int    @id @default(autoincrement())
  title    String
  content  String
  author   User   @relation(fields: [authorId], references: [id])
  authorId Int
}
