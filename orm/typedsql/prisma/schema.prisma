generator client {
  provider        = "prisma-client"
  output          = "./generated"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  trackingEvents TrackingEvent[]
}

model TrackingEvent {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  userId    String
  type      String
  variant   String
  user      User     @relation(fields: [userId], references: [id])
}
