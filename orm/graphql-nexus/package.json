{
  "name": "typescript-graphql-nexus",
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/server",
    "start": "node dist/server",
    "clean": "rm -rf dist",
    "build": "npm -s run clean && npm -s run generate && tsc",
    "generate": "npm -s run generate:prisma && npm -s run generate:nexus",
    "generate:prisma": "prisma generate",
    "generate:nexus": "tsx src/schema"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@apollo/server": "4.12.2",
    "@prisma/client": "7.0.0",
    "dotenv": "^17.2.1",
    "@prisma/adapter-pg": "7.0.0",
    "graphql": "16.11.0",
    "graphql-scalars": "1.24.2",
    "nexus": "1.3.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "22.18.12",
    "prisma": "7.0.0",
    "tsx": "4.20.6",
    "typescript": "5.8.2",
    "@types/pg": "^8.15.6"
  }
}