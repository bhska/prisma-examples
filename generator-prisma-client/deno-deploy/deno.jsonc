{
  "name": "generator-prisma-client-deno-deploy",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno serve --allow-env --allow-sys --allow-read --allow-net --env-file=.env ./src/main.ts",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/http": "jsr:@std/http@1",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^6.18.0",
    "@prisma/client": "npm:@prisma/client@^6.18.0",
    "dotenv": "npm:dotenv@^17.2.1",
    "prisma": "npm:prisma@^6.18.0"
  },
  "nodeModulesDir": "auto",
  "deploy": {
    "exclude": [
      "**/node_modules"
    ],
    "include": [],
    "entrypoint": "src/main.ts"
  }
}