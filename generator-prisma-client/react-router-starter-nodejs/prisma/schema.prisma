generator client {
  provider   = "prisma-client"
  output     = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum QuoteKind {
  Fact
  Opinion
}

model Quotes {
  id        Int       @id @default(autoincrement())
  quote     String
  kind      QuoteKind @default(Opinion)
  createdAt DateTime  @default(now())
}
