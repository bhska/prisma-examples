{
  "compilerOptions": {
    "strict": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "types": [
      "node",
      "vite/client"
    ],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  }
}
