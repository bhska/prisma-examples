generator client {
  provider   = "prisma-client"
  output     = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  content   String
  vote      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
