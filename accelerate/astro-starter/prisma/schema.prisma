// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client"
  output     = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
}
